.env.*
.env.local
.env.production
*.key
*.pem
*.p12
*.pfx
secrets.json
credentials.json

# ── IDE and editor files ──────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath

# ── OS generated files ────────────────────────────────────────────────────────
